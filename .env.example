# ─────────────────────────────────────────────────────────────────
# OperateHQ — local dev environment variables
# Copy this file to .env (and apps/web/.env.local) and fill in.
# ─────────────────────────────────────────────────────────────────

# ── Control plane database (one DB for all tenants' metadata) ──
CONTROL_DATABASE_URL="postgresql://operate:operate@localhost:5432/operate_control?schema=public"

# ── Tenant database connection template ──
# When provisioning a new tenant, we create a NEW database on this server
# and store the per-tenant connection string in the control plane.
# This is the admin connection used by the provisioning CLI.
TENANT_DB_ADMIN_URL="postgresql://operate:operate@localhost:5432/postgres"
TENANT_DB_HOST="localhost"
TENANT_DB_PORT="5432"
TENANT_DB_USER="operate"
TENANT_DB_PASSWORD="operate"

# ── Auth (NextAuth) ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-me-in-prod-use-openssl-rand-base64-32"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (magic-link). In dev, points to maildev container.
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="OperateHQ <noreply@operatehq.local>"

# ── AI ──
ANTHROPIC_API_KEY=""

# ── Payments (Stripe Connect) — leave blank until Phase 10 ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# ── Object storage (S3-compatible — MinIO locally) ──
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="operate"
S3_SECRET_KEY="operate-secret"
S3_BUCKET="operate-uploads"

# ── Tenant routing ──
# Apex domain for subdomain resolution. In dev, configure your hosts file
# or use *.localhost (most browsers route *.localhost -> 127.0.0.1).
APP_DOMAIN="operatehq.localhost"
APP_ADMIN_SLUG="admin"
APP_CUSTOMER_SLUG="book"
